	<><template>
  <div v-bind:class={"w-100"}></>
  <div v-bind:[some]={{ [some]: 2 }}></>
  <Some v-slot:default={}>{{ default: ({ a }) => <></> }}</>
  <input v-model:={text}></>
  <Some v-bind:some.none={1}></>
  <div v-bind:id={id}></>
  <div v-bind:msg-id={msgId}></>
</template>
</>;
};


